# ── Database ────────────────────────────────────────────────────────────
# Leave DATABASE_URL unset for local development — the app uses a local
# SQLite file at ./data/local.db automatically (auto-created and seeded).
#
# In production (Railway), set DATABASE_URL to your Postgres connection
# string. Railway's Postgres plugin provides this automatically; reference it
# in your service variables as:
#   DATABASE_URL=${{ Postgres.DATABASE_URL }}
DATABASE_URL=

# Optional: override the local SQLite file location.
# SQLITE_PATH=./data/local.db

# ── Auth ────────────────────────────────────────────────────────────────
# Long random string used to sign JWTs. REQUIRED in production.
JWT_SECRET=change-me-to-a-long-random-string

# ── AI matrimony matching (OpenAI) ──────────────────────────────────────
# Optional. Without it, compatibility falls back to the built-in rule-based
# scoring (religion + rasi + age). With it, the profile modal's "detailed
# analysis" uses OpenAI.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
